// Prisma schema for Dev Portfolio Analyzer
// Target: Neon PostgreSQL (project divine-snow-13292795)
// Run: pnpm prisma generate && pnpm prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── Auth (Better Auth) ─────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts            Account[]
  sessions            Session[]
  githubConnections   GitHubConnection[]
  resumes             Resume[]
  careerRoadmaps      CareerRoadmap[]
  reports             Report[]
  activitySnapshots   ActivitySnapshot[]
  feedback            Feedback[]
  aiUsages            AIUsage[]
  adminLogs           AdminLog[]

  @@index([email])
}

model Account {
  id                    String   @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?  @db.Text
  refreshToken          String?  @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?  @db.Text
  password              String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ───────────────────────── GitHub ─────────────────────────

model GitHubConnection {
  id         String   @id @default(cuid())
  userId     String
  username   String
  avatarUrl  String?
  accessToken String?  @db.Text
  scope      String?
  isActive   Boolean  @default(true)
  lastSyncAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositories Repository[]

  @@unique([userId, username])
  @@index([userId])
}

model Repository {
  id                String   @id @default(cuid())
  connectionId      String
  githubRepoId      Int
  name              String
  fullName          String
  description       String?  @db.Text
  url               String
  language          String?
  languages         Json?    // { "TypeScript": 12000, ... }
  starCount         Int      @default(0)
  forkCount         Int      @default(0)
  primaryFramework  String?
  hasReadme         Boolean  @default(false)
  hasTests          Boolean  @default(false)
  hasCI             Boolean  @default(false)
  hasLicense        Boolean  @default(false)
  isDeployed        Boolean  @default(false)
  loc               Int?
  lastCommitAt      DateTime?
  ingestedAt        DateTime @default(now())

  connection GitHubConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  analysis   Analysis?

  @@unique([connectionId, githubRepoId])
  @@index([connectionId])
}

// ───────────────────────── Analysis ─────────────────────────

model Analysis {
  id                  String   @id @default(cuid())
  repositoryId        String   @unique
  overallScore        Int      // 0-100
  hiringReadiness     Int      // 0-100
  level               DevLevel
  repoQuality         Int
  commitConsistency   Int
  readmeQuality       Int
  documentation       Int
  complexity          Int
  architecture        Int
  portfolioCompleteness Int
  deploymentStatus    Int
  uiQuality           Int?
  strengths           Json     // string[]
  weaknesses          Json     // string[]
  missingProjects     Json     // string[]
  recommendedTech     Json     // string[]
  raw                 Json?    // full AI payload
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId])
}

// ───────────────────────── Resume ─────────────────────────

model Resume {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("My Resume")
  content   String   @db.Text
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeAnalysis  ResumeAnalysis?

  @@index([userId])
}

model ResumeAnalysis {
  id                String   @id @default(cuid())
  resumeId          String   @unique
  score             Int
  strengths         Json
  weaknesses        Json
  suggestions       Json     // resume improvement suggestions
  missingKeywords   Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

// ───────────────────────── Career ─────────────────────────

model CareerRoadmap {
  id        String   @id @default(cuid())
  userId    String
  level     DevLevel
  title     String
  steps     Json     // structured roadmap steps
  techToLearn Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ───────────────────────── Reports ─────────────────────────

model Report {
  id          String   @id @default(cuid())
  userId      String
  type        ReportType
  title       String
  shareToken  String   @unique @default(uuid())
  isPublic    Boolean  @default(false)
  pdfUrl      String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([shareToken])
}

// ───────────────────────── Activity / Skills ─────────────────────────

model ActivitySnapshot {
  id            String   @id @default(cuid())
  userId        String
  weekStart     DateTime
  commits       Int      @default(0)
  pullRequests  Int      @default(0)
  issues        Int      @default(0)
  reviews       Int      @default(0)
  activeDays    Int      @default(0)
  languages     Json?
  createdAt     DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillProgress SkillProgress[]

  @@unique([userId, weekStart])
  @@index([userId])
}

model SkillProgress {
  id          String   @id @default(cuid())
  snapshotId  String
  skill       String
  category    SkillCategory
  level       Int      // 0-100 proficiency
  trend       Float    // delta vs previous

  snapshot ActivitySnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
}

// ───────────────────────── Feedback / AI / Admin ─────────────────────────

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  rating    Int      // 1-5
  message   String?  @db.Text
  status    FeedbackStatus @default(OPEN)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model AIUsage {
  id           String   @id @default(cuid())
  userId       String?
  feature      String   // "analysis" | "coach" | "resume"
  provider     String   // "openai" | "openrouter"
  model        String
  promptTokens Int      @default(0)
  completionTokens Int  @default(0)
  costUsd      Float    @default(0)
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entity    String?
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

// ───────────────────────── Enums ─────────────────────────

enum Role {
  USER
  ADMIN
}

enum DevLevel {
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum ReportType {
  PORTFOLIO
  RESUME
  CAREER
}

enum SkillCategory {
  LANGUAGE
  FRAMEWORK
  TOOLING
  SOFT
  DOMAIN
}

enum FeedbackStatus {
  OPEN
  REVIEWED
  RESOLVED
}
